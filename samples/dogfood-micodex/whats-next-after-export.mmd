    classDef question fill:#fff3e0,stroke:#ff8f00,stroke-dasharray:5,color:#5a3a00

    class Deploy1,Deploy2,Deploy3,Deploy4 exists
    class Comm1,Comm2 partial
    class Comm3,Comm4 gap
    class Pin1,Pin2,Pin3 gap
    class Share1,Share2,Share3 partial
    class Iterate chrome
    class What,NextChoice question
    class Export,CollExp,ConstrExp exists

    style deploy fill:#f5fff5,stroke:#2e7d32
    style pin fill:#fff5f5,stroke:#c62828,stroke-dasharray:3
    style comm fill:#fffaf0,stroke:#f9a825
    style share fill:#fffaf0,stroke:#f9a825
